{
  "name": "buisz-iptv",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Buisz IPTV — Netflix-stijl player voor M3U & Xtream",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:proxy": "VITE_PROXY_BASE=/__proxy npm run build",
    "preview": "vite preview",
    "serve": "node server/proxy.mjs",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "mpegts.js": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "regenerator-runtime": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "terser": "^5.48.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "whatwg-fetch": "^3.6.20"
  }
}
